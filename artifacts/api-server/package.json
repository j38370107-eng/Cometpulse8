{
  "name": "@workspace/api-server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "fuser -k 3000/tcp 2>/dev/null; sleep 1; export NODE_ENV=development && pnpm run build && pnpm run start",
