    "@workspace/api-zod": "workspace:*",
    "@workspace/db": "workspace:*",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "discord.js": "^14.26.4",
    "distube": "^5.2.3",
    "drizzle-orm": "catalog:",
    "express": "^5.2.1",
    "ffmpeg-static": "^5.3.0",
    "opusscript": "^0.1.1",
    "pg": "^8.20.0",
    "pino": "^9.14.0",
    "pino-http": "^10.5.0",
    "play-dl": "^1.9.7"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.10",
